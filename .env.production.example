APP_DOMAIN=futura-expert.com
APP_WWW_DOMAIN=www.futura-expert.com
LETSENCRYPT_EMAIL=contact@futura-expert.com

NODE_ENV=production
PORT=4000
TRUST_PROXY=true
SWAGGER_ENABLED=false
ALLOW_INSECURE_ORIGIN=false
PASSWORD_POLICY_STRICT=true

WEB_ORIGIN=https://futura-expert.com
NEXT_PUBLIC_API_URL=/api

POSTGRES_DB=pointage360
POSTGRES_USER=pointage360
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://pointage360:replace-with-a-long-random-database-password@postgres:5432/pointage360?schema=public

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters-access
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=redis
REDIS_PORT=6379
AUTH_CONTEXT_CACHE_ENABLED=true
AUTH_CONTEXT_CACHE_TTL_SECONDS=30

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=pointage360

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Futura Expertise <noreply@futura-expert.com>
