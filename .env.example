DATABASE_URL="postgresql://pointage360:pointage360@127.0.0.1:5432/pointage360?schema=public"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
AUTH_CONTEXT_CACHE_ENABLED="true"
AUTH_CONTEXT_CACHE_TTL_SECONDS=30
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="pointage360"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
WEB_ORIGIN="http://localhost:3000"
NODE_ENV="development"
SWAGGER_ENABLED="true"
TRUST_PROXY="false"
PASSWORD_POLICY_STRICT="false"
# Production only: set to "true" only for temporary non-HTTPS staging.
ALLOW_INSECURE_ORIGIN="false"

# SMTP (optionnel - emails loggues en dev si absent)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Pointage360 <noreply@pointage360.app>"
